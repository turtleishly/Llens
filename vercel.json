{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/llens",
      "destination": "/llens/index.html"
    },
    {
      "source": "/llens/start",
      "destination": "/llens/start/index.html"
    },
    {
      "source": "/llens/guide",
      "destination": "/llens/guide/index.html"
    },
    {
      "source": "/llens/chapter-1",
      "destination": "/llens/chapter-1/index.html"
    },
    {
      "source": "/llens/chapter-2",
      "destination": "/llens/chapter-2/index.html"
    },
    {
      "source": "/llens/chapter-2/game",
      "destination": "/llens/chapter-2/game/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
