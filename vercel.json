{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/about",
      "destination": "/about/index.html"
    },
    {
      "source": "/history",
      "destination": "/history/index.html"
    },
    {
      "source": "/impact",
      "destination": "/impact/index.html"
    },
    {
      "source": "/news",
      "destination": "/news/index.html"
    },
    {
      "source": "/contact",
      "destination": "/contact/index.html"
    },
    {
      "source": "/terms",
      "destination": "/terms/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy/index.html"
    },
    {
      "source": "/meet-the-team",
      "destination": "/meet-the-team/index.html"
    },
    {
      "source": "/meet-the-team-2023-2024",
      "destination": "/meet-the-team-2023-2024/index.html"
    },
    {
      "source": "/meet-the-team-2022-2023",
      "destination": "/meet-the-team-2022-2023/index.html"
    },
    {
      "source": "/meet-the-team-2021-2022",
      "destination": "/meet-the-team-2021-2022/index.html"
    },
    {
      "source": "/naic",
      "destination": "/naic/index.html"
    },
    {
      "source": "/naic/register",
      "destination": "/naic/register/index.html"
    },
    {
      "source": "/naic/faq",
      "destination": "/naic/faq/index.html"
    },
    {
      "source": "/naic/tracks",
      "destination": "/naic/tracks/index.html"
    },
    {
      "source": "/naic/contact",
      "destination": "/naic/contact/index.html"
    },
    {
      "source": "/naic/terms",
      "destination": "/naic/terms/index.html"
    },
    {
      "source": "/naic/privacy",
      "destination": "/naic/privacy/index.html"
    },
    {
      "source": "/llens/guide",
      "destination": "/llens/guide/index.html"
    },
    {
      "source": "/llens/chapter-1",
      "destination": "/llens/chapter-1/index.html"
    },
    {
      "source": "/llens/chapter-2",
      "destination": "/llens/chapter-2/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
